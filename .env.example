# Local defaults
CASES_DIR=./data
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=admin
VITE_APP_TITLE=QA Test Result
# Optional: set to false to disable unauthenticated Teams/preview crawler access
ALLOW_UNAUTHENTICATED_LINK_PREVIEW=true
# Used to sign public metadata-only share links
SHARE_TOKEN_SECRET=change-me-share-secret
# Share-link time-to-live in seconds (default: 7 days)
SHARE_LINK_TTL_SECONDS=604800
